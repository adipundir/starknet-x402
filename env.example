# Starknet x402 Environment Configuration (SNIP-9 Outside Execution)

# Starknet Network
STARKNET_NODE_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_8/demo

# Client Account (Payer)
CLIENT_PRIVATE_KEY=0x...
CLIENT_ADDRESS=0x...
NEXT_PUBLIC_CLIENT_PRIVATE_KEY=0x...

# Recipient Account (Payee - receives payments)
RECIPIENT_ADDRESS=0x...

# Facilitator
FACILITATOR_URL=http://localhost:3000/api/facilitator

# Token - USDC (Circle native, 6 decimals)
# Sepolia: 0x0512feAc6339Ff7889822cb5aA2a86C848e9D392bB0E3E237C008674feeD8343
# Mainnet: 0x033068F6539f8e6e6b131e6B2B814e6c34A5224bC66947c47DaB9dFeE93b35fb
TOKEN_ADDRESS=0x0512feAc6339Ff7889822cb5aA2a86C848e9D392bB0E3E237C008674feeD8343

# AVNU Paymaster (required — handles gas sponsoring and SNIP-9 execution)
# Get API key at https://docs.avnu.fi
# Sepolia: https://sepolia.paymaster.avnu.fi
# Mainnet: https://starknet.paymaster.avnu.fi
