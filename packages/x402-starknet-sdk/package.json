{
  "name": "starknet-x402",
  "version": "1.0.5",
  "description": "x402 v2 payment protocol for Starknet — trustless HTTP-native payments via SNIP-9",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "x402",
    "starknet",
    "payments",
    "snip-9",
    "micropayments",
    "usdc"
  ],
  "author": "Aditya Pundir",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.0.0",
    "starknet": "^7.0.0"
  },
  "peerDependencies": {
    "next": "^15.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.21",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adipundir/starknet-x402.git"
  },
  "bugs": {
    "url": "https://github.com/adipundir/starknet-x402/issues"
  },
  "homepage": "https://github.com/adipundir/starknet-x402#readme"
}
